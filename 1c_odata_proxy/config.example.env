# Скопируйте в .env и подставьте свои значения.
# Запуск: в PowerShell — $env:ONEC_BACKEND_BASE="..."; node server.js
#         в Linux/Mac — export ONEC_BACKEND_BASE="..."; node server.js

# URL сервера 1С (без завершающего слэша).
# Пример: http://172.22.0.62/1R82821/1R82821_AVTOSERV30_73qj8uuuxp
ONEC_BACKEND_BASE=http://172.22.0.62/1R82821/1R82821_AVTOSERV30_73qj8uuuxp

# Пользователь и пароль 1С (подставляются в заголовок Authorization).
ONEC_USERNAME=Администратор
ONEC_PASSWORD=

# Порт, на котором слушает прокси (по умолчанию 3080).
PORT=3080
